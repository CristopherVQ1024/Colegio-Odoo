<odoo>
    <record id="view_cuota_form" model="ir.ui.view">
        <field name="name">colegio.cuota.form</field>
        <field name="model">colegio.cuota</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="colegiado_id"/>
                        <field name="periodo"/>
                        <field name="monto"/>
                        <field name="fecha_vencimiento"/>
                        <field name="estado"/>
                    </group>
                    <notebook>
                        <page string="Pagos">
                            <field name="pago_ids">
                                <tree editable="bottom">
                                    <field name="fecha_pago"/>
                                    <field name="monto_pagado"/>
                                    <field name="metodo_pago"/>
                                    <field name="numero_comprobante"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_cuota_list" model="ir.ui.view">
        <field name="name">colegio.cuota.list</field>
        <field name="model">colegio.cuota</field>
        <field name="arch" type="xml">
            <tree>
                <field name="colegiado_id"/>
                <field name="periodo"/>
                <field name="monto"/>
                <field name="fecha_vencimiento"/>
                <field name="estado"/>
            </tree>
        </field>
    </record>

    <record id="action_cuota" model="ir.actions.act_window">
        <field name="name">Cuotas</field>
        <field name="res_model">colegio.cuota</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_cuota" name="Cuotas" parent="menu_colegio_root" action="action_cuota" sequence="25"/>
</odoo>