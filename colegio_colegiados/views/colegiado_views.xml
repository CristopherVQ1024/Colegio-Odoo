<odoo>
    <record id="view_colegiado_list" model="ir.ui.view">
        <field name="name">colegio.colegiado.list</field>
        <field name="model">colegio.colegiado</field>
        <field name="arch" type="xml">
            <tree>
                <field name="numero_colegiatura"/>
                <field name="nombres"/>
                <field name="apellidos"/>
                <field name="especialidad_id"/>
                <field name="estado"/>
            </tree>
        </field>
    </record>

    <record id="view_colegiado_form" model="ir.ui.view">
        <field name="name">colegio.colegiado.form</field>
        <field name="model">colegio.colegiado</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="numero_colegiatura"/>
                            <field name="dni"/>
                            <field name="nombres"/>
                            <field name="apellidos"/>
                            <field name="fecha_nacimiento"/>
                        </group>
                        <group>
                            <field name="especialidad_id"/>
                            <field name="direccion"/>
                            <field name="telefono"/>
                            <field name="correo"/>
                            <field name="fecha_colegiacion"/>
                            <field name="estado"/>
                            <field name="user_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Cuotas">
                            <field name="cuota_ids">
                                <tree editable="bottom">
                                    <field name="periodo"/>
                                    <field name="monto"/>
                                    <field name="fecha_vencimiento"/>
                                    <field name="estado"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_colegiado" model="ir.actions.act_window">
        <field name="name">Colegiados</field>
        <field name="res_model">colegio.colegiado</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Vistas de Especialidad -->
    <record id="view_especialidad_list" model="ir.ui.view">
        <field name="name">colegio.especialidad.list</field>
        <field name="model">colegio.especialidad</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="descripcion"/>
            </tree>
        </field>
    </record>

    <record id="view_especialidad_form" model="ir.ui.view">
        <field name="name">colegio.especialidad.form</field>
        <field name="model">colegio.especialidad</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="descripcion"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_especialidad" model="ir.actions.act_window">
        <field name="name">Especialidades</field>
        <field name="res_model">colegio.especialidad</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_colegio_root" name="Colegio"/>
    <menuitem id="menu_colegiado" name="Colegiados" parent="menu_colegio_root" action="action_colegiado" sequence="10"/>
    <menuitem id="menu_especialidad" name="Especialidades" parent="menu_colegio_root" action="action_especialidad" sequence="20"/>
</odoo>