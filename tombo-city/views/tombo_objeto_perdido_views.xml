<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tombo_objeto_perdido_list" model="ir.ui.view">
        <field name="name">tombo.objeto.perdido.list</field>
        <field name="model">tombo.objeto.perdido</field>
        <field name="arch" type="xml">
            <list string="Objetos Perdidos" decoration-muted="estado=='devuelto'">
                <field name="name"/>
                <field name="descripcion"/>
                <field name="lugar_hallazgo"/>
                <field name="fecha_hallazgo"/>
                <field name="comisaria_id"/>
                <field name="estado" widget="badge" decoration-info="estado=='custodia'" decoration-success="estado=='devuelto'" decoration-warning="estado=='no_reclamado'"/>
            </list>
        </field>
    </record>

    <record id="view_tombo_objeto_perdido_kanban" model="ir.ui.view">
        <field name="name">tombo.objeto.perdido.kanban</field>
        <field name="model">tombo.objeto.perdido</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="descripcion"/>
                <field name="imagen"/>
                <field name="estado"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_image">
                                <img t-att-src="kanban_image('tombo.objeto.perdido', 'imagen', record.id.raw_value)" alt="Objeto"/>
                            </div>
                            <strong><field name="name"/></strong>
                            <div><field name="descripcion"/></div>
                            <field name="estado" widget="badge"/>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_tombo_objeto_perdido_form" model="ir.ui.view">
        <field name="name">tombo.objeto.perdido.form</field>
        <field name="model">tombo.objeto.perdido</field>
        <field name="arch" type="xml">
            <form string="Objeto Perdido">
                <header>
                    <button name="action_marcar_devuelto" type="object" string="Marcar como Devuelto" class="btn-primary" invisible="estado != 'custodia'"/>
                    <button name="action_marcar_no_reclamado" type="object" string="Marcar No Reclamado" invisible="estado != 'custodia'"/>
                    <button name="action_reabrir_custodia" type="object" string="Reabrir a Custodia" invisible="estado == 'custodia'"/>
                    <field name="estado" widget="statusbar" statusbar_visible="custodia,devuelto"/>
                </header>
                <sheet>
                    <field name="imagen" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="lugar_hallazgo"/>
                            <field name="fecha_hallazgo"/>
                            <field name="encontrado_por"/>
                            <field name="comisaria_id"/>
                        </group>
                    </group>
                    <group string="Descripción">
                        <field name="descripcion" nolabel="1"/>
                    </group>
                    <group string="Entrega al Propietario" invisible="estado != 'devuelto'">
                        <group>
                            <field name="propietario_id"/>
                            <field name="propietario_nombre"/>
                            <field name="propietario_dni"/>
                        </group>
                        <group>
                            <field name="fecha_entrega"/>
                            <field name="entregado_por_id"/>
                        </group>
                        <field name="observaciones_entrega" nolabel="1" colspan="2"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tombo_objeto_perdido_search" model="ir.ui.view">
        <field name="name">tombo.objeto.perdido.search</field>
        <field name="model">tombo.objeto.perdido</field>
        <field name="arch" type="xml">
            <search string="Buscar Objetos Perdidos">
                <field name="name"/>
                <field name="descripcion"/>
                <field name="lugar_hallazgo"/>
                <filter string="En Custodia" name="custodia" domain="[('estado','=','custodia')]"/>
                <filter string="Devueltos" name="devuelto" domain="[('estado','=','devuelto')]"/>
                <filter string="No Reclamados" name="no_reclamado" domain="[('estado','=','no_reclamado')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Estado" name="group_estado" context="{'group_by':'estado'}"/>
                    <filter string="Comisaría" name="group_comisaria" context="{'group_by':'comisaria_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_tombo_objeto_perdido" model="ir.actions.act_window">
        <field name="name">Objetos Perdidos</field>
        <field name="res_model">tombo.objeto.perdido</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_custodia': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Registra un objeto encontrado</p>
        </field>
    </record>

</odoo>
