<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_tombo_denuncia" model="ir.sequence">
            <field name="name">Tombo City - Denuncia</field>
            <field name="code">tombo.denuncia</field>
            <field name="prefix">DEN-%(year)s-</field>
            <field name="padding">5</field>
            <field name="company_id" eval="False"/>
        </record>

