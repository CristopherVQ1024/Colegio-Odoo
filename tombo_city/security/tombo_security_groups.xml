<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_tombo_city" model="ir.module.category">
            <field name="name">Tombo City</field>
            <field name="description">Gestión Policial Municipal</field>
            <field name="sequence">20</field>
        </record>

        <!-- 3. Comisario / Supervisor -->
        <record id="group_tombo_comisario" model="res.groups">
            <field name="name">Comisario / Supervisor</field>
            <field name="category_id" ref="module_category_tombo_city"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Aprueba permisos, revisa denuncias, asigna responsables y ve reportes. No configura el sistema.</field>
        </record>

        <!-- 2. Personal de Comisaría -->
        <record id="group_tombo_personal_comisaria" model="res.groups">
            <field name="name">Personal de Comisaría</field>
            <field name="category_id" ref="module_category_tombo_city"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
            <field name="comment">Registra y actualiza denuncias, incidencias, objetos perdidos, permisos de eventos y administra recursos policiales.</field>
        </record>

        <!-- 1. Administrador -->
        <record id="group_tombo_administrador" model="res.groups">
            <field name="name">Administrador</field>
            <field name="category_id" ref="module_category_tombo_city"/>
            <field name="implied_ids" eval="[(4, ref('group_tombo_comisario')), (4, ref('group_tombo_personal_comisaria'))]"/>
            <field name="comment">Configura el sistema completo: usuarios, comisarías, policías y recursos. Ve todos los módulos.</field>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
