<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tombo_policia_list" model="ir.ui.view">
        <field name="name">tombo.policia.list</field>
        <field name="model">tombo.policia</field>
        <field name="arch" type="xml">
            <tree string="Personal Policial" decoration-muted="estado=='inactivo'">
                <field name="name"/>
                <field name="dni"/>
                <field name="cargo"/>
                <field name="area"/>
                <field name="comisaria_id"/>
                <field name="telefono"/>
                <field name="estado" widget="badge" decoration-success="estado=='activo'" decoration-warning="estado=='vacaciones'" decoration-danger="estado=='inactivo'"/>
            </tree>
        </field>
    </record>

    <record id="view_tombo_policia_form" model="ir.ui.view">
        <field name="name">tombo.policia.form</field>
        <field name="model">tombo.policia</field>
        <field name="arch" type="xml">
            <form string="Personal Policial">
                <header>
                    <field name="estado" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_denuncias" type="object" class="oe_stat_button" icon="fa-file-text">
                            <field name="denuncia_count" widget="statinfo" string="Denuncias"/>
                        </button>
                        <button name="action_view_recursos" type="object" class="oe_stat_button" icon="fa-car">
                            <field name="recurso_count" widget="statinfo" string="Recursos"/>
                        </button>
                    </div>
                    <field name="foto" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Nombre completo"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="dni"/>
                            <field name="codigo_placa"/>
                            <field name="cargo"/>
                            <field name="area"/>
                        </group>
                        <group>
                            <field name="comisaria_id"/>
                            <field name="telefono"/>
                            <field name="email"/>
                            <field name="user_id"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tombo_policia_search" model="ir.ui.view">
        <field name="name">tombo.policia.search</field>
        <field name="model">tombo.policia</field>
        <field name="arch" type="xml">
            <search string="Buscar Personal">
                <field name="name"/>
                <field name="dni"/>
                <field name="comisaria_id"/>
                <filter string="Activos" name="activos" domain="[('estado','=','activo')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Comisaría" name="group_comisaria" context="{'group_by':'comisaria_id'}"/>
                    <filter string="Cargo" name="group_cargo" context="{'group_by':'cargo'}"/>
                    <filter string="Área" name="group_area" context="{'group_by':'area'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_tombo_policia" model="ir.actions.act_window">
        <field name="name">Personal Policial</field>
        <field name="res_model">tombo.policia</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Registra un nuevo policía</p>
        </field>
    </record>

</odoo>
