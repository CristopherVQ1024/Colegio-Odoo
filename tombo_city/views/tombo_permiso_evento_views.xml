<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tombo_permiso_evento_list" model="ir.ui.view">
        <field name="name">tombo.permiso.evento.list</field>
        <field name="model">tombo.permiso.evento</field>
        <field name="arch" type="xml">
            <tree string="Permisos para Eventos" decoration-danger="estado=='rechazado'" decoration-success="estado=='aprobado'">
                <field name="name"/>
                <field name="organizador_nombre"/>
                <field name="tipo_evento"/>
                <field name="fecha_evento"/>
                <field name="lugar_evento"/>
                <field name="estado" widget="badge" decoration-info="estado=='solicitado'" decoration-warning="estado=='en_revision'" decoration-success="estado=='aprobado'" decoration-danger="estado=='rechazado'"/>
            </tree>
        </field>
    </record>

    <record id="view_tombo_permiso_evento_form" model="ir.ui.view">
        <field name="name">tombo.permiso.evento.form</field>
        <field name="model">tombo.permiso.evento</field>
        <field name="arch" type="xml">
            <form string="Permiso para Evento">
                <header>
                    <button name="action_enviar_revision" type="object" string="Enviar a Revisión" class="btn-primary" invisible="estado != 'solicitado'"/>
                    <button name="action_aprobar" type="object" string="Aprobar" class="btn-primary" invisible="estado != 'en_revision'" groups="tombo_city.group_tombo_comisario,tombo_city.group_tombo_administrador"/>
                    <button name="action_rechazar" type="object" string="Rechazar" invisible="estado != 'en_revision'" groups="tombo_city.group_tombo_comisario,tombo_city.group_tombo_administrador"/>
                    <field name="estado" widget="statusbar" statusbar_visible="solicitado,en_revision,aprobado"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Datos del Organizador">
                            <field name="partner_id"/>
                            <field name="organizador_nombre"/>
                            <field name="organizador_dni"/>
                            <field name="organizador_telefono"/>
                            <field name="organizador_email"/>
                        </group>
                        <group string="Datos del Evento">
                            <field name="tipo_evento"/>
                            <field name="fecha_evento"/>
                            <field name="fecha_fin_evento"/>
                            <field name="lugar_evento"/>
                            <field name="aforo_estimado"/>
                            <field name="comisaria_id"/>
                        </group>
                    </group>
                    <group string="Descripción">
                        <field name="descripcion" nolabel="1"/>
                    </group>
                    <group string="Revisión" invisible="estado == 'solicitado'">
                        <group>
                            <field name="revisado_por_id"/>
                            <field name="fecha_revision"/>
                        </group>
                    </group>
                    <group string="Observaciones">
                        <field name="observaciones" nolabel="1"/>
                        <field name="motivo_rechazo" nolabel="1" invisible="estado != 'rechazado'"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_tombo_permiso_evento_search" model="ir.ui.view">
        <field name="name">tombo.permiso.evento.search</field>
        <field name="model">tombo.permiso.evento</field>
        <field name="arch" type="xml">
            <search string="Buscar Permisos">
                <field name="name"/>
                <field name="organizador_nombre"/>
                <field name="lugar_evento"/>
                <filter string="Solicitados" name="solicitados" domain="[('estado','=','solicitado')]"/>
                <filter string="En Revisión" name="en_revision" domain="[('estado','=','en_revision')]"/>
                <filter string="Aprobados" name="aprobados" domain="[('estado','=','aprobado')]"/>
                <filter string="Rechazados" name="rechazados" domain="[('estado','=','rechazado')]"/>
                <group expand="0" string="Agrupar por">
                    <filter string="Estado" name="group_estado" context="{'group_by':'estado'}"/>
                    <filter string="Tipo de Evento" name="group_tipo" context="{'group_by':'tipo_evento'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_tombo_permiso_evento" model="ir.actions.act_window">
        <field name="name">Permisos para Eventos</field>
        <field name="res_model">tombo.permiso.evento</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_solicitados': 1, 'search_default_en_revision': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Registra una solicitud de permiso para evento</p>
        </field>
    </record>

</odoo>
